# Copy this file to .env.local for local development, and set the same
# variables in your Vercel project settings for production.
# Never commit real values.

# Neon Postgres connection string (the Vercel Neon integration can set this).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Google Cloud API key with "Places API (New)" enabled.
GOOGLE_PLACES_API_KEY="your-google-places-api-key"

# The shared password used to log into the app.
APP_PASSWORD="choose-a-strong-password"

# A random string used to sign the login cookie (generate a long random value).
AUTH_SECRET="replace-with-a-long-random-string"

# --- AI outreach (optional) — the customer's own Anthropic API key ---
# Enables the "outreach" action that drafts a personalized message per lead.
# Server-side only, billed to this key. Get one at https://console.anthropic.com/ .
# ANTHROPIC_API_KEY="your-anthropic-api-key"
# Model for drafts (default claude-opus-4-8). Set claude-haiku-4-5 for lower cost.
# OUTREACH_MODEL="claude-opus-4-8"

# --- Branding (white-label) — all optional, safe to expose to the browser ---
# These are baked into the client at build time, so change them and redeploy.
# NEXT_PUBLIC_APP_NAME="Prospector"                 # header + browser title
# NEXT_PUBLIC_APP_TAGLINE="B2B lead pipeline"       # small subtitle ("" hides it)
# NEXT_PUBLIC_LOGO_URL="https://.../logo.svg"       # logo image (omit for text only)
# NEXT_PUBLIC_ACCENT="#ff6b00"                      # accent color (buttons/links/focus)
# NEXT_PUBLIC_ACCENT_DARK="#c2560a"                 # accent hover/link shade
# NEXT_PUBLIC_COMPANY_NAME="Your Company Ltd"       # footer business name
# NEXT_PUBLIC_COMPANY_URL="https://yourcompany.com" # footer link
# NEXT_PUBLIC_FOOTER_NOTE="hello@yourcompany.com · +90 ..."  # extra footer line
# NEXT_PUBLIC_SHOW_ADS="1"                          # show the ad slot (ad-supported tier)

# --- v2 (market intelligence, not required for v1) ---
# Free UN Comtrade API key for steel-door import stats (HS 730830).
# Register at https://comtradedeveloper.un.org/ . See docs/V2.md.
# COMTRADE_API_KEY="your-un-comtrade-api-key"

# --- v3 (geography: continent > country > top cities) ---
# Free GeoNames username. Register at https://www.geonames.org/login and then
# enable web services on your account page.
# GEONAMES_USERNAME="your-geonames-username"
