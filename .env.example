# Copy this file to .env.local for local development, and set the same
# variables in your Vercel project settings for production.
# Never commit real values.

# Neon Postgres connection string (the Vercel Neon integration can set this).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Google Cloud API key with "Places API (New)" enabled.
GOOGLE_PLACES_API_KEY="your-google-places-api-key"

# The shared password used to log into the app.
APP_PASSWORD="choose-a-strong-password"

# A random string used to sign the login cookie (generate a long random value).
AUTH_SECRET="replace-with-a-long-random-string"

# --- v2 (market intelligence, not required for v1) ---
# Free UN Comtrade API key for steel-door import stats (HS 730830).
# Register at https://comtradedeveloper.un.org/ . See docs/V2.md.
# COMTRADE_API_KEY="your-un-comtrade-api-key"
